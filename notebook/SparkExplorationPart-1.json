			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql import functions as F"
				],
				"execution_count": 3
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"adls_path = \"abfss://synapse-container@rainbowstorageadls.dfs.core.windows.net/apple_global_sales_dataset.csv\"\n",
					"\n",
					"sales_df = (\n",
					"    spark.read.format(\"csv\")\n",
					"    .option(\"header\", True)\n",
					"    .option(\"inferSchema\", True)\n",
					"    .load(adls_path)\n",
					")\n",
					"\n",
					"# display(sales_df)"
				],
				"execution_count": 2
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"sales_q4 = sales_df.filter(F.col(\"quarter\") == \"Q4\")\n",
					"# display(sales_q4)"
				],
				"execution_count": 5
			},
			{
				"cell_type": "code",
				"source": [
					"sales_q4.write.format(\"parquet\").save(\"/notebook/salesQ4\")"
				],
				"execution_count": 6
			}
		]
	}
